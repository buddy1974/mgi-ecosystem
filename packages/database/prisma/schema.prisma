generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum GlobalRole {
  SUPER_ADMIN
  USER
}

enum CompanyRole {
  ADMIN
  MANAGER
  STAFF
  GUEST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
}

enum ApprovalCategory {
  FINANCE
  PROCUREMENT
  HIRING
  MARKETING
  OPERATIONS
  LEGAL
}

enum ApprovalPriority {
  CRITICAL
  HIGH
  NORMAL
  LOW
}

enum NotificationPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum NotificationChannel {
  in_app
  email
  push
}

enum SocialPostStatus {
  DRAFT
  AWAITING_APPROVAL
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  DELEGATE
  LOGIN
  LOGOUT
  VIEW
}

enum MessageSource {
  EMAIL
  WHATSAPP
  LINKEDIN
  INSTAGRAM
  TIKTOK
  FACEBOOK
  INTERNAL
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// ─── GLOBAL MODELS ────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  avatar        String?
  globalRole    GlobalRole @default(USER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  memberships   CompanyMembership[]
  tasks         Task[]              @relation("TaskAssignee")
  createdTasks  Task[]              @relation("TaskCreator")
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  domain      String?
  logo        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships CompanyMembership[]
  tasks       Task[]
  notifications Notification[]
  socialPosts  SocialPost[]
  bookings    Booking[]
  workflowRuns WorkflowRun[]
  auditLogs   AuditLog[]
  embeddings  VectorEmbedding[]

  @@map("companies")
}

model CompanyMembership {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole @default(STAFF)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("company_memberships")
}

// ─── FEATURE MODELS (all company-scoped) ──────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  companyId   String
  title       String
  description String?
  assigneeId  String?
  creatorId   String
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company     Company @relation(fields: [companyId], references: [id])
  assignee    User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator     User    @relation("TaskCreator", fields: [creatorId], references: [id])

  @@index([companyId, status])
  @@index([assigneeId])
  @@map("tasks")
}

model Approval {
  id            String           @id @default(cuid())
  companyId     String
  category      ApprovalCategory
  title         String
  description   String           @db.Text
  amount        Float?
  currency      String           @default("XAF")
  requestedBy   String
  requestedAt   DateTime         @default(now())
  status        ApprovalStatus   @default(PENDING)
  priority      ApprovalPriority @default(NORMAL)
  n8nWorkflow   String?
  aiAnalysis    String?          @db.Text
  aiRisk        String?
  decidedAt     DateTime?
  decidedBy     String?
  delegatedTo   String?
  rejectionNote String?
  auditLog      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status, priority, requestedAt])
  @@index([companyId, status])
  @@map("approvals")
}

model Notification {
  id        String               @id @default(cuid())
  userId    String
  companyId String?
  type      String
  title     String
  body      String
  data      Json?
  priority  NotificationPriority @default(NORMAL)
  channel   NotificationChannel  @default(in_app)
  read      Boolean              @default(false)
  readAt    DateTime?
  createdAt DateTime             @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

model SocialPost {
  id          String           @id @default(cuid())
  companyId   String
  content     String           @db.Text
  platforms   Json
  mediaUrls   Json?
  scheduledAt DateTime?
  publishedAt DateTime?
  status      SocialPostStatus @default(DRAFT)
  creatorId   String
  n8nWorkflowId String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company     Company @relation(fields: [companyId], references: [id])

  @@index([companyId, status])
  @@index([scheduledAt])
  @@map("social_posts")
}

model Booking {
  id          String   @id @default(cuid())
  companyId   String
  title       String
  hostId      String
  guestEmail  String?
  guestName   String?
  startAt     DateTime
  endAt       DateTime
  status      String   @default("confirmed")
  notes       String?
  meetingUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company @relation(fields: [companyId], references: [id])

  @@index([companyId, startAt])
  @@map("bookings")
}

model WorkflowRun {
  id              String   @id @default(cuid())
  companyId       String
  n8nWorkflowId   String
  n8nWorkflowName String?
  triggeredBy     String?
  status          String   @default("running")
  result          Json?
  error           String?
  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  company         Company @relation(fields: [companyId], references: [id])

  @@index([companyId, startedAt])
  @@map("workflow_runs")
}

model AuditLog {
  id          String      @id @default(cuid())
  companyId   String?
  userId      String?
  action      AuditAction
  resource    String
  resourceId  String?
  before      Json?
  after       Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  company     Company? @relation(fields: [companyId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([userId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

model VectorEmbedding {
  id           String   @id @default(cuid())
  companyId    String
  content      String   @db.Text
  embedding    Unsupported("vector(1536)")?
  resourceType String
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  company      Company @relation(fields: [companyId], references: [id])

  @@index([companyId, resourceType])
  @@map("vector_embeddings")
}

// ─── COMMUNICATIONS ───────────────────────────────────────────────────────────

model Message {
  id          String           @id @default(cuid())
  externalId  String?          @unique
  companyId   String
  source      MessageSource
  direction   MessageDirection @default(INBOUND)
  fromName    String
  fromHandle  String?
  fromAvatar  String?
  subject     String?
  body        String           @db.Text
  bodyHtml    String?          @db.Text
  receivedAt  DateTime
  isRead      Boolean          @default(false)
  isArchived  Boolean          @default(false)
  isStarred   Boolean          @default(false)
  aiSummary   String?          @db.Text
  aiDraft     String?          @db.Text
  aiActToday  Boolean          @default(false)
  delegatedTo String?
  threadId    String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([companyId, source, receivedAt])
  @@index([isRead, aiActToday])
  @@map("messages")
}

// ─── CALENDAR ─────────────────────────────────────────────────────────────────

enum EventType {
  MEETING
  CALL
  CONFERENCE
  INTERNAL
  PERSONAL
  TRAVEL
}

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DECLINED
}

model Event {
  id          String      @id @default(cuid())
  companyId   String?
  title       String
  description String?
  type        EventType   @default(MEETING)
  status      EventStatus @default(CONFIRMED)
  startAt     DateTime
  endAt       DateTime
  location    String?
  attendees   String[]
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([startAt, status])
  @@map("events")
}

model BookingRequest {
  id             String        @id @default(cuid())
  companyId      String?
  requesterName  String
  requesterEmail String
  requesterPhone String?
  purpose        String
  requestedDate  DateTime
  duration       Int
  status         BookingStatus @default(PENDING)
  declinedReason String?
  respondedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, requestedDate])
  @@map("booking_requests")
}
